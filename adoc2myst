#!/usr/bin/env bash

set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  SCRIPT_DIR="$(cd -P -- "$(dirname -- "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$SCRIPT_DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P -- "$(dirname -- "$SOURCE")" && pwd)"
REPO_ROOT="$SCRIPT_DIR"

OUTPUT_OVERRIDE=""
DOC4_DIR_OVERRIDE=""
MODULES_DIR=""
INPUT=""
DEBUG="${DEBUG:-0}"

usage() {
  echo "Usage: $0 --modules-dir /path/to/modules [-o output.md] [--doc4-dir /path/to/folder] <input.adoc>"
}

# --- Parse args (order-independent) ---
while [[ $# -gt 0 ]]; do
  case "$1" in
    -o)
      OUTPUT_OVERRIDE="$2"
      shift 2
      ;;
    --doc4-dir)
      DOC4_DIR_OVERRIDE="$2"
      shift 2
      ;;
    --modules-dir)
      MODULES_DIR="$2"
      shift 2
      ;;
    -*)
      echo "Unknown option: $1"
      usage
      exit 1
      ;;
    *)
      INPUT="$1"
      shift
      ;;
  esac
done

# --- Input validation ---
if [[ -z "$INPUT" || -z "$MODULES_DIR" ]]; then
  usage
  exit 1
fi

if [[ ! -f "$INPUT" ]]; then
  echo "Error: file not found: $INPUT"
  exit 1
fi

if [[ ! -d "$MODULES_DIR" ]]; then
  echo "Error: modules directory not found: $MODULES_DIR"
  exit 1
fi

# Normalize modules path
MODULES_DIR="$(cd "$MODULES_DIR" && pwd)"

# --- Derive names ---
BASENAME="$(basename "$INPUT" .adoc)"

# --- Temp working directory ---
TMPDIR="$(mktemp -d)"

if [[ "$DEBUG" -eq 1 ]]; then
  echo "DEBUG: using temp dir: $TMPDIR"
else
  trap 'rm -rf "$TMPDIR"' EXIT
fi

# --- Intermediate XML output handling ---
if [[ -n "$DOC4_DIR_OVERRIDE" ]]; then
  mkdir -p "$DOC4_DIR_OVERRIDE"
  XML_WORK_DIR="$DOC4_DIR_OVERRIDE"
else
  XML_WORK_DIR="$TMPDIR"
fi

DOC5="$XML_WORK_DIR/doc5.xml"
DOC5_NONS="$XML_WORK_DIR/doc5-nons.xml"
DOC4="$XML_WORK_DIR/doc4.xml"

# --- Output handling ---
if [[ -n "$OUTPUT_OVERRIDE" ]]; then
  OUTPUT_MD="$OUTPUT_OVERRIDE"
else
  OUTPUT_MD="$(dirname "$INPUT")/${BASENAME}.md"
fi

mkdir -p "$(dirname "$OUTPUT_MD")"

# --- Configure dbcookbook location ---
DBCOOKBOOK_DIR="${DBCOOKBOOK_DIR:-$REPO_ROOT/dbcookbook}"
XSL_DIR="$DBCOOKBOOK_DIR/en/xml/structure/db5-to-db4"
XSL_FILE="$XSL_DIR/db5to4.xsl"

if [[ ! -f "$XSL_FILE" ]]; then
  echo "Error: db5to4.xsl not found at: $XSL_FILE"
  echo "Set DBCOOKBOOK_DIR to the correct location."
  exit 1
fi

# --- Step 1: AsciiDoc -> DocBook 5 ---
asciidoctor -b docbook "$INPUT" -o "$DOC5"

# --- Step 2: Strip DocBook 5 namespace ---
sed 's/xmlns="http:\/\/docbook.org\/ns\/docbook"//' "$DOC5" > "$DOC5_NONS"

# --- Step 3: Down-convert DocBook 5 -> DocBook 4 ---
xsltproc \
  --path "$XSL_DIR" \
  "$XSL_FILE" \
  "$DOC5_NONS" > "$DOC4"

# --- Step 4: DocBook 4 -> MyST Markdown ---
python3 "$SCRIPT_DIR/convert.py" "$DOC4" "$OUTPUT_MD" "$MODULES_DIR" > "$OUTPUT_MD"

echo "Done: $OUTPUT_MD"
echo "DocBook 5 file: $DOC5"
echo "Namespace-stripped DocBook 5 file: $DOC5_NONS"
echo "DocBook 4 file: $DOC4"

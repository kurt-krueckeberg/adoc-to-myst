#!/usr/bin/env bash
set -euo pipefail

# Simple wrapper for jb1_to_jb2_myst.py
#
# Normal use:
#   jb1tojb2 SOURCE_DIR DEST_DIR
#
# Example:
#   jb1tojb2 ~/sphinx-nla ~/jupyter-nla
#
# What it does:
#   - recursively converts .md files from SOURCE_DIR
#   - writes converted files to DEST_DIR
#   - rewrites local .md links to JB2 folder-style links
#
# It runs this converter:
#   ~/adoc-to-myst/jb1_to_jb2_myst.py

CONVERTER="$HOME/adoc-to-myst/jb1_to_jb2_myst.py"

usage() {
  cat <<'EOF'
Usage:
  jb1tojb2 SOURCE_DIR DEST_DIR

Example:
  jb1tojb2 ~/sphinx-nla ~/jupyter-nla

Meaning:
  SOURCE_DIR   Your existing JB1/Sphinx MyST project or folder of .md files.
  DEST_DIR     The JB2 destination folder where converted .md files will be written.

This wrapper automatically uses:
  --recursive      Convert .md files in subdirectories too.
  --folder-links   Convert links like doc1.md to doc1/ for JB2 folder URLs.

EOF
}

if [[ $# -eq 0 || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -ne 2 ]]; then
  echo "Error: expected exactly two arguments: SOURCE_DIR DEST_DIR" >&2
  echo >&2
  usage >&2
  exit 1
fi

if [[ ! -f "$CONVERTER" ]]; then
  echo "Error: converter script not found: $CONVERTER" >&2
  exit 1
fi

SRC="$1"
DST="$2"

python3 "$CONVERTER" "$SRC" "$DST" --recursive --folder-links

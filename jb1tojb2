#!/usr/bin/env bash
set -euo pipefail

# Wrapper for jb1_to_jb2_myst.py.
#
# Single-file use:
#   jb1tojb2 SOURCE.md DEST.md
#
# Directory use:
#   jb1tojb2 SOURCE_DIR DEST_DIR
#
# The wrapper always uses --folder-links. It uses --recursive only when
# SOURCE is a directory.

CONVERTER="${JB1_TO_JB2_CONVERTER:-$HOME/adoc-to-myst/jb1_to_jb2_myst.py}"

usage() {
  cat <<'EOF'
Usage:
  jb1tojb2 SOURCE.md DEST.md
  jb1tojb2 SOURCE_DIR DEST_DIR

Examples:
  jb1tojb2 ~/sphinx-nla/1237/example.md ~/jupyter-nla/1237/example.md
  jb1tojb2 ~/sphinx-nla ~/jupyter-nla

Meaning:
  SOURCE.md   One JB1/Sphinx MyST Markdown file.
  DEST.md     One JB2/MyST Markdown output file.

  SOURCE_DIR  Folder containing JB1/Sphinx MyST Markdown files.
  DEST_DIR    JB2 destination folder where converted .md files are written.

This wrapper automatically uses:
  --folder-links   Convert links like doc1.md to doc1/ for JB2 folder URLs.

For directory input, it also uses:
  --recursive      Convert .md files in subdirectories too.

Set JB1_TO_JB2_CONVERTER=/path/to/jb1_to_jb2_myst.py to override the converter path.
EOF
}

if [[ $# -eq 0 || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -ne 2 ]]; then
  echo "Error: expected exactly two arguments: SOURCE DEST" >&2
  echo >&2
  usage >&2
  exit 1
fi

if [[ ! -f "$CONVERTER" ]]; then
  echo "Error: converter script not found: $CONVERTER" >&2
  exit 1
fi

SRC="$1"
DST="$2"

if [[ -f "$SRC" ]]; then
  python3 "$CONVERTER" "$SRC" "$DST" --folder-links
elif [[ -d "$SRC" ]]; then
  python3 "$CONVERTER" "$SRC" "$DST" --recursive --folder-links
else
  echo "Error: source is not a file or directory: $SRC" >&2
  exit 1
fi
